<?xml version="1.0" encoding="UTF-8"?>
<beans xmlns="http://www.springframework.org/schema/beans"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xmlns:context="http://www.springframework.org/schema/context" xsi:schemaLocation="
        http://www.springframework.org/schema/beans http://www.springframework.org/schema/beans/spring-beans.xsd
        http://www.springframework.org/schema/context http://www.springframework.org/schema/context/spring-context.xsd"> <!-- bean definitions here -->
<context:annotation-config/>
<bean id="emp" class="com.cg.bean.Employee">
<property name="employeeId" value="101"/>
<property name="employeeName" value="Mohit"/>
<property name="salary" value="76000.00"/>
<property name="businessUnit" value="abc"/>
<property name="age" value="25"/>
<property name="sbu" ref="e1"/>
</bean>
<bean id="e1" class="com.cg.bean.SBU">
<property name="sbuId" value="1001"/>
<property name="sbuName" value="ABC"/>
<property name="sbuHead" value="Rohan Kumar"/>
</bean>
<bean id="emp1" class="com.cg.bean.Employee">
    <property name="employeeId" value="101"/>
    <property name="employeeName" value="Mohit"/>
    <property name="salary" value="76000.00"/>
    <property name="businessUnit" value="sbe"/>
    <property name="age" value="25"/>
    <property name="sbu" ref="sbu"/>
</bean>

<bean id="emp2" class="com.cg.bean.Employee">
    <property name="employeeId" value="102"/>
    <property name="employeeName" value="Ankit"/>
    <property name="salary" value="89000"/>
    <property name="businessUnit" value="sbe"/>
    <property name="age" value="28"/>
    <property name="sbu" ref="sbu"/>
</bean>
<bean id="sbu" class="com.cg.bean.SBU">
    <property name="sbuId" value="1001"/>
    <property name="sbuName" value="ABC"/>
    <property name="sbuHead" value="Rohan Kumar"/>
    <property name="empList">
        <list>
            <ref bean="emp1"/>
            <ref bean="emp2"/>
        </list>
    </property>

</bean>
</beans>
