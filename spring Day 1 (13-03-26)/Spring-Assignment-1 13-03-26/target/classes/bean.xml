<?xml version="1.0" encoding="UTF-8"?>
<beans xmlns="http://www.springframework.org/schema/beans"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xmlns:context="http://www.springframework.org/schema/context" xsi:schemaLocation="
        http://www.springframework.org/schema/beans http://www.springframework.org/schema/beans/spring-beans.xsd
        http://www.springframework.org/schema/context http://www.springframework.org/schema/context/spring-context.xsd"> <!-- bean definitions here -->
<context:annotation-config/>
<bean id="ee" class="com.cg.bean.Employee">
<property name="employeeId" value="125"/>
<property name="employeeName" value="Siddhant"/>
<property name="salary" value="85983.34"/>
<property name="businessUnit" value="xyz"/>
<property name="age" value="21"/>
<property name="sbu" ref="e1"/>
</bean>
<bean id="e1" class="com.cg.bean.SBU">
<property name="sbuId" value="1011"/>
<property name="sbuName" value="ABC"/>
<property name="sbuHead" value="Mr Atul Singh"/>
</bean>
<bean id="emp1" class="com.cg.bean.Employee">
    <property name="employeeId" value="125"/>
    <property name="employeeName" value="Siddhant"/>
    <property name="salary" value="85983.34"/>
    <property name="businessUnit" value="PES"/>
    <property name="age" value="21"/>
    <property name="sbu" ref="sbuPES"/>
</bean>

<bean id="emp2" class="com.cg.bean.Employee">
    <property name="employeeId" value="126"/>
    <property name="employeeName" value="Rahul"/>
    <property name="salary" value="75000"/>
    <property name="businessUnit" value="PES"/>
    <property name="age" value="25"/>
    <property name="sbu" ref="sbuPES"/>
</bean>
<bean id="sbuPES" class="com.cg.bean.SBU">
    <property name="sbuId" value="1011"/>
    <property name="sbuName" value="PES"/>
    <property name="sbuHead" value="Mr Atul Singh"/>

    <!-- Inject Employee List -->
    <property name="empList">
        <list>
            <ref bean="emp1"/>
            <ref bean="emp2"/>
        </list>
    </property>

</bean>
</beans>